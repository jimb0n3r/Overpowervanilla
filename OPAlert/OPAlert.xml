<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/">
    <Script file="OPAlert.lua"/>
    
    <Frame name="OPAlertFrame" parent="UIParent" hidden="true" frameStrata="MEDIUM" movable="true" clampedToScreen="true">
        <Size>
            <AbsDimension x="64" y="64"/>
        </Size>
        <Anchors>
            <Anchor point="CENTER" relativeTo="UIParent" relativePoint="CENTER" x="0" y="-100"/>
        </Anchors>
        
        <!-- Overpower Icon -->
        <Layers>
            <Layer level="ARTWORK">
                <Texture name="OPAlertIcon" file="Interface\Icons\Ability_MeleeDamage">
                    <Size>
                        <AbsDimension x="64" y="64"/>
                    </Size>
                    <Anchors>
                        <Anchor point="CENTER"/>
                    </Anchors>
                </Texture>
            </Layer>
        </Layers>
        
        <Scripts>
            <OnLoad>OPAlert_OnLoad();</OnLoad>
            <OnEvent>OPAlert_OnEvent();</OnEvent>
            <OnUpdate>OPAlert_OnUpdate(arg1);</OnUpdate>
            <OnMouseDown>OPAlert_OnMouseDown();</OnMouseDown>
            <OnMouseUp>OPAlert_OnMouseUp();</OnMouseUp>
        </Scripts>
    </Frame>
</Ui>